@model MyCityProject.Models.District

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Add District";
}

<section class="admin-page py-5">
    <div class="container">
        <div class="page-panel admin-form-panel">

            <div class="mb-4">
                <h1>Add New District</h1>
                <p class="text-muted mb-0">
                    Create a new district entry for the Bingöl City Web Portal.
                </p>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">District Name</label>
                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Example: Solhan" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="5"
                              placeholder="Write a short description about this district."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ImagePath" class="form-label">Image Path</label>
                    <input asp-for="ImagePath"
                           class="form-control"
                           placeholder="/images/bingol-solhan.jpg" />
                    <span asp-validation-for="ImagePath" class="text-danger"></span>
                    <div class="form-text">
                        Use a relative image path from the wwwroot folder, for example:
                        <code>/images/bingol-solhan.jpg</code>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Create
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </form>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}