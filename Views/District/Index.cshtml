@model IEnumerable<MyCityProject.Models.District>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Districts";
}

<section class="district-page py-5">
    <div class="container">

        <div class="page-panel mb-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h1 class="mb-2">Districts of Bingöl</h1>
                    <p class="text-muted mb-0">
                        Explore Bingöl's districts, rural landscapes and local settlements.
                    </p>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> Add District
                    </a>
                }
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center shadow-sm">
                @ViewBag.Error
            </div>
        }
        else if (ViewBag.Message != null)
        {
            <div class="alert alert-warning text-center shadow-sm">
                @ViewBag.Message
            </div>
        }
        else if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var district in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="district-card h-100">
                            <img src="@district.ImagePath"
                                alt="@district.Name"
                                class="district-card-img"
                                onerror="this.onerror=null; this.src='/images/bingol1.jpg';" />

                            <div class="district-card-body">
                                <h5>@district.Name</h5>
                                <p>@district.Description</p>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-2 mt-3">
                                        <a asp-action="Edit"
                                           asp-route-id="@district.Id"
                                           class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit me-1"></i>Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@district.Id"
                                           class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash me-1"></i>Delete
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="page-panel text-center">
                <h4>No district data is available yet.</h4>
                <p class="text-muted mb-0">
                    District information can be added by an administrator.
                </p>
            </div>
        }
    </div>
</section>